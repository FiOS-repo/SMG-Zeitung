---
let articles = [];

try {
  const response = await fetch('https://wp.fiosproject.de/wp-json/wp/v2/posts?per_page=4');
  const data = await response.json();
  // Map each post to an object with title and slug
  articles = data.map((post) => ({
    title: post.title.rendered,
    slug: post.slug
  }));
} catch (error) {
  console.error('Error fetching articles:', error);
}
---

<div class="bg-blue-200 rounded-3xl bg-clip-padding backdrop-filter backdrop-blur-3xl bg-opacity-20 ring-1 ring-blue-200 p-6 shadow-lg w-full mb-10">
  <div class="text-2xl text-blue-900 font-bold">Neueste Beiträge </div>
  <div class="mt-4">
    <p class="text-lg text-gray-800">Die Neusten Beiträge auf der SMGZ</p>
    <div class="mt-4">
      {articles.map((article) => (
        <div>
          <a class="text-gray-700" href={`/article/${article.slug}/`}>
            {article.title}
          </a>
          <br />
        </div>
      ))}
    </div>
  </div>
</div>
