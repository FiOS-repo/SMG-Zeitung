---
import Button from "../Button.astro";
---
<div class="bg-blue-200 rounded-3xl bg-clip-padding backdrop-filter backdrop-blur-3xl bg-opacity-20 ring-1 ring-blue-200 p-6 shadow-lg mb-10 w-full">
  <div class="text-2xl text-blue-900 font-bold">Umfrage</div>
  <div class="mt-4">
    <p id="question" class="text-lg text-gray-800">Lädt...</p>
    <div id="answers" class="mt-4">
      <p class="text-gray-500">Lädt Antworten...</p>
    </div>
    <div id="results" class="mt-4 hidden">
      <canvas id="resultsChart"></canvas>
    </div>
  </div>
  <Button text="Abstimmen" onclick="submitAnswer()" />
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script client:load>
  let question = "Lädt...";
  let parsedAnswers = [];
  let selectedAnswer = "";
  let pollId = 0;

  // Update the UI based on fetched data
  function updateUI() {
    document.getElementById("question").innerText = question;
    const answersContainer = document.getElementById("answers");
    answersContainer.innerHTML = "";
    parsedAnswers.forEach(answer => {
      const label = document.createElement("label");
      label.className = "flex items-center mb-2 option";
      label.innerHTML = `
        <input type="radio" name="os" class="mr-2" value="${answer}" onchange="setSelectedAnswer('${answer}')" />
        <span class="text-gray-700">${answer}</span>
      `;
      answersContainer.appendChild(label);
    });
    parsedAnswers.forEach(answer => {
      const bar = document.createElement("div");
      bar.className = "bg-blue-200 rounded-full h-2 w-0 mt-2";
      bar.innerHTML = `
        <div class="bg-blue-500 rounded-full h-2 w-10" class="bar-${answer}"></div>
      `;
    })
  }

  // Global function to update the selected answer (accessible from inline event handlers)
  window.setSelectedAnswer = (answer) => {
    selectedAnswer = answer;
  };

  // Fetch poll data from the API and update the UI
  function loadPoll() {
    fetch("http://localhost:3000/api/poll/")
      .then(response => {
        if (!response.ok) {
          throw new Error("Fehler beim Laden der Umfrage");
        }
        return response.json();
      })
      .then(data => {
        question = data.question;
        parsedAnswers = data.options;
        pollId = data.id;
        updateUI();
      })
      .catch(error => {
        console.error("Fehler beim Abrufen der Umfrage:", error);
        question = "Fehler beim Laden der Umfrage.";
        updateUI();
      });
  }

  let resultsChart = null;

  // Function to fetch and display results
  async function showResults() {
    try {
      const response = await fetch(`http://localhost:3000/api/poll/results?id=${pollId}`);
      if (!response.ok) throw new Error("Failed to fetch results");
      const answers = await response.json();
      
      // Calculate percentages
      const counts = {};
      answers.forEach(answer => {
        counts[answer] = (counts[answer] || 0) + 1;
      });
      
      const total = answers.length;
      
      // Prepare data for chart
      const data = parsedAnswers.map(answer => ({
        label: answer,
        value: counts[answer] || 0,
        percentage: total ? Math.round(((counts[answer] || 0) / total) * 100) : 0
      }));

      // Show results container and hide answers
      document.getElementById('results').classList.remove('hidden');
      document.getElementById('answers').classList.add('hidden');

      // Destroy existing chart if it exists
      if (resultsChart) {
        resultsChart.destroy();
      }

      // Create new chart
      const ctx = document.getElementById('resultsChart');
      resultsChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: data.map(item => item.label),
          datasets: [{
            data: data.map(item => item.percentage),
            backgroundColor: 'rgba(59, 130, 246, 0.8)',
            borderColor: 'rgba(59, 130, 246, 1)',
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              callbacks: {
                label: (context) => `${context.raw}% (${data[context.dataIndex].value} votes)`
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 100,
              ticks: {
                callback: value => value + '%'
              }
            }
          }
        }
      });

    } catch (error) {
      console.error("Error fetching results:", error);
    }
  }

  // Submit the selected answer to the API
  window.submitAnswer = async () => {
    if (!selectedAnswer) {
      alert("Bitte wähle eine Antwort aus.");
      return;
    }

    try {
      const response = await fetch(`http://localhost:3000/api/poll/answer?id=${pollId}&answer=${selectedAnswer}`, {
        method: "GET"
      });
      
      if (!response.ok) {
        throw new Error("Fehler beim Absenden der Antwort");
      }
      
      // Show results after successful submission
      await showResults();
      
    } catch (error) {
      console.error("Fehler beim Absenden:", error);
      alert("Fehler beim Speichern der Antwort.");
    }
  };

  // Run loadPoll once the DOM content is loaded
  document.addEventListener("DOMContentLoaded", loadPoll);
</script>
